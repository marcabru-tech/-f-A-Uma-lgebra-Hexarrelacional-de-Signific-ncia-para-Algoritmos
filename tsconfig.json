{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom","dom.iterable","esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {"@/*":["./src/*"]},
    "strict": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "outDir": "./dist"
  },
  "include": ["src/**/*","next-env.d.ts"]
}
